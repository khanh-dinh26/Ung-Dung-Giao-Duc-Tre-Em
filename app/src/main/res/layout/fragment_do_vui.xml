<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/layout_start_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="30dp"
        android:visibility="invisible">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="40dp"
            app:cardElevation="10dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="50dp"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRÒ CHƠI"
                    android:textColor="#264635"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="30dp"
                    android:text="ĐỐ VUI"
                    android:textColor="#FFB74D"
                    android:textSize="45sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_marginBottom="40dp"
                    android:src="@drawable/quiz" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_game"
                    android:layout_width="220dp"
                    android:layout_height="65dp"
                    android:text="BẮT ĐẦU ▶"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FFB74D"
                    app:cornerRadius="20dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
    <LinearLayout
        android:id="@+id/layout_game_play"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:paddingHorizontal="25dp"
            android:gravity="center">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                app:cardBackgroundColor="#FFF3E0"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/tv_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="10dp"
                    android:text="⭐ 0"
                    android:textColor="#F57C00"
                    android:textSize="25sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="25dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#2E5C41"
            app:cardCornerRadius="25dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="25dp">

                <TextView
                    android:id="@+id/tv_question"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Câu hỏi..."
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btn_play_question"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginLeft="20dp"
                    android:src="@drawable/play"
                    app:tint="#D5AA04"
                    />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_option_1"
                    android:soundEffectsEnabled="false"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_marginHorizontal="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="8dp"
                    app:strokeColor="#FFB74D"
                    app:strokeWidth="5dp">
                    <ImageView
                        android:id="@+id/img_option_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_option_2"
                    android:soundEffectsEnabled="false"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_marginHorizontal="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="8dp"
                    app:strokeColor="#FFB74D"
                    app:strokeWidth="5dp">
                    <ImageView
                        android:id="@+id/img_option_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_option_3"
                    android:soundEffectsEnabled="false"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_marginHorizontal="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="8dp"
                    app:strokeColor="#FFB74D"
                    app:strokeWidth="5dp">
                    <ImageView
                        android:id="@+id/img_option_3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_option_4"
                    android:soundEffectsEnabled="false"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_marginHorizontal="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="8dp"
                    app:strokeColor="#FFB74D"
                    app:strokeWidth="5dp">
                    <ImageView
                        android:id="@+id/img_option_4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>