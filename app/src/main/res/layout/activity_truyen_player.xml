<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFCFA"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <ImageView
            android:id="@+id/btn_player_back"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:soundEffectsEnabled="false"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#264635"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="ĐANG PHÁT TRUYỆN"
            android:textColor="#757575"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <TextView
        android:id="@+id/tv_player_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Tên câu chuyện"
        android:textColor="#264635"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginVertical="40dp"
        app:cardCornerRadius="120dp"
        app:cardElevation="8dp"
        app:strokeWidth="4dp"
        app:strokeColor="#FFB74D">
        <ImageView
            android:id="@+id/img_player_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
    </com.google.android.material.card.MaterialCardView>

    <SeekBar
        android:id="@+id/player_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:progressTint="#2E5C41"
        android:thumbTint="#FFB74D"/>

    <ImageView
        android:id="@+id/btn_player_play_pause"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="30dp"
        android:clickable="true"
        android:focusable="true"
        android:soundEffectsEnabled="false"
        android:src="@android:drawable/ic_media_pause"
        app:tint="#2E5C41" />

</LinearLayout>