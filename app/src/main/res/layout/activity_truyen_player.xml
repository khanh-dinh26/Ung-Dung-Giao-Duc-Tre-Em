<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/player_bg"
    android:padding="25dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <ImageView
            android:id="@+id/btn_player_back"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_centerVertical="true"
            android:soundEffectsEnabled="false"
            android:src="@drawable/back"
            app:tint="#264635"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="ĐANG PHÁT TRUYỆN"
            android:textColor="#757575"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_player_favorite"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/btn_star_big_off"
            app:tint="#F57C00"/>
    </RelativeLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="25dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="35dp"
        app:cardElevation="5dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="35dp"
            android:paddingHorizontal="15dp">

            <TextView
                android:id="@+id/tv_player_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên câu chuyện"
                android:textColor="#264635"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="35dp"/>

            <RelativeLayout
                android:layout_width="260dp"
                android:layout_height="260dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="130dp"
                    app:cardElevation="5dp"
                    app:strokeWidth="5dp"
                    app:strokeColor="#FFB74D">

                    <ImageView
                        android:id="@+id/img_player_cover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_centerInParent="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="#FFB74D"/>
            </RelativeLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <SeekBar
        android:id="@+id/player_seekbar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="10dp"
        android:paddingVertical="10dp"
        android:progressDrawable="@drawable/custom_seekbar"
        android:thumb="@drawable/custom_thumb"
        android:thumbOffset="0dp"
        android:splitTrack="false"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="45dp"
        app:cardElevation="5dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="30dp"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/btn_player_rewind"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_marginRight="25dp"
                android:clickable="true"
                android:focusable="true"
                android:soundEffectsEnabled="false"
                android:src="@android:drawable/ic_media_rew"
                app:tint="#2E5C41" />

            <FrameLayout
                android:layout_width="75dp"
                android:layout_height="75dp">

                <ImageView
                    android:id="@+id/btn_player_play_pause"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:soundEffectsEnabled="false"
                    android:src="@android:drawable/ic_media_pause"
                    app:tint="#2E5C41"
                    android:visibility="invisible"/>

                <ProgressBar
                    android:id="@+id/progress_loading_audio"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#FFB74D" />
            </FrameLayout>

            <ImageView
                android:id="@+id/btn_player_forward"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_marginLeft="25dp"
                android:clickable="true"
                android:focusable="true"
                android:soundEffectsEnabled="false"
                android:src="@android:drawable/ic_media_ff"
                app:tint="#2E5C41" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>